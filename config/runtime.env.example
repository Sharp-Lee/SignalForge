# Copy this file to .local/runtime.env for project-local runtime overrides.
# This repo is public. Real API keys must live outside the repo, normally at:
#   ~/.config/news-llm/keys.env
# Never put real keys in .local/, config/, docs/, or any committed file.

# Scheduled mode: capture | analyze | pipeline. LaunchAgent plists set this explicitly.
NEWS_RUN_MODE="pipeline"

# RSS sources. Leave NEWS_RSS_FEED_URL unset to use the configured narrow source set
# from config/rss_sources.example.json or .local/rss_sources.json.
# NEWS_RSS_FEED_URL="https://www.servethehome.com/feed/"
# NEWS_RSS_FEED_URLS="https://www.servethehome.com/feed/,https://www.eetimes.com/feed/"
# NEWS_RSS_SOURCES_FILE=".local/rss_sources.json"

# Repo-external secrets path. The wrapper creates the parent directory but not the key file.
NEWS_KEYS_FILE="$HOME/.config/news-llm/keys.env"

# Project-local runtime state. These paths are gitignored.
NEWS_STORE_PATH=".local/news-data/live-store.db"
NEWS_LOG_DIR=".local/news-data/logs"

# macOS Homebrew Python used by launchd. Override if your machine differs.
NEWS_PYTHON="/opt/homebrew/opt/python@3.12/libexec/bin/python3"

# Local proxy used by DeepSeek/OpenAI-compatible endpoints in this environment.
NEWS_HTTP_PROXY="http://127.0.0.1:6152"

# Pending analyze budget and safety caps.
NEWS_ANALYZE_TOP_K="5"
NEWS_PENDING_MAX_AGE_DAYS="7"
NEWS_MAX_ANALYSIS_ATTEMPTS="2"

# Keep scheduled logs useful even on no-new-signal days.
NEWS_SHOW_STORE_AFTER_RUN="1"
