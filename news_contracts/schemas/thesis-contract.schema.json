{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "thesis-contract",
  "type": "object",
  "required": ["id", "body", "source_signal_ids", "status", "confidence"],
  "properties": {
    "id": {"type": "string"},
    "body": {"type": "string"},
    "source_signal_ids": {"type": "array", "items": {"type": "string"}},
    "substantive_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["text", "source_signal_ids"],
        "properties": {
          "text": {"type": "string", "minLength": 1},
          "source_signal_ids": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "direction": {"type": "string", "enum": ["bullish", "bearish", "neutral", "mixed"]},
    "origin_market": {"type": "string"},
    "target_market": {"type": "string"},
    "transmission_path": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "source_signal_ids"],
        "properties": {
          "description": {"type": "string", "minLength": 1},
          "source_signal_ids": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "completeness_critique": {
      "type": "object",
      "required": ["notes", "candidate_thesis_ids", "body_unchanged"],
      "properties": {
        "notes": {"type": "array", "items": {"type": "string"}},
        "candidate_thesis_ids": {"type": "array", "items": {"type": "string"}},
        "body_unchanged": {"type": "boolean"}
      }
    },
    "status": {"type": "string", "enum": ["draft", "unconfirmed", "confirmed", "rejected"]},
    "confidence": {"type": "string", "enum": ["low", "medium", "high"]},
    "uncertainty_tags": {"type": "array", "items": {"type": "string"}},
    "adversarial_falsification": {
      "type": "object",
      "required": ["reviewer", "review_session", "strongest_counterargument", "hedge_variables"],
      "properties": {
        "reviewer": {"type": "string", "minLength": 1},
        "review_session": {
          "type": "object",
          "required": ["thesis_author_id", "author_persona", "reviewer_instance_id", "reviewer_persona", "review_run_id"],
          "properties": {
            "thesis_author_id": {"type": "string", "minLength": 1},
            "author_persona": {"type": "string", "minLength": 1},
            "reviewer_instance_id": {"type": "string", "minLength": 1},
            "reviewer_persona": {"type": "string", "minLength": 1},
            "review_run_id": {"type": "string", "minLength": 1}
          }
        },
        "strongest_counterargument": {"type": "string", "minLength": 1},
        "hedge_variables": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      }
    },
    "track_record": {
      "type": "object",
      "required": ["direction", "falsifiable_expectation", "verification_window", "created_at"],
      "properties": {
        "direction": {"type": "string", "enum": ["bullish", "bearish", "neutral", "mixed"]},
        "falsifiable_expectation": {"type": "string", "minLength": 1},
        "verification_window": {
          "type": "object",
          "required": ["start", "end"],
          "properties": {
            "start": {"type": "string", "minLength": 1},
            "end": {"type": "string", "minLength": 1}
          }
        },
        "created_at": {"type": "string", "minLength": 1}
      }
    }
  }
}
